{
  "name": "@ops/gateway",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/static": "^8.2.0",
    "@ops/config": "workspace:*",
    "@ops/db": "workspace:*",
    "@ops/memory": "workspace:*",
    "@ops/observability": "workspace:*",
    "@ops/queue": "workspace:*",
    "@ops/runtime": "workspace:*",
    "@ops/shared": "workspace:*",
    "@ops/skills": "workspace:*",
    "fastify": "^5.6.1",
    "fastify-plugin": "^5.0.1",
    "nanoid": "^5.1.6"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json --force",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "lint": "eslint src --ext .ts",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  }
}
