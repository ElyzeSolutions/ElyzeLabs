{
  "name": "ops-control-plane",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=10.30.3 <11"
  },
  "scripts": {
    "dev": "pnpm dev:split",
    "dev:split": "bash -lc 'trap \"kill 0\" EXIT; pnpm dev:gateway & for i in {1..240}; do curl -fs http://127.0.0.1:8788/api/health/readiness >/dev/null && break; sleep 0.25; if [ \"$i\" -eq 240 ]; then echo \"Gateway readiness timeout (60s)\"; exit 1; fi; done; pnpm dev:dashboard'",
    "dev:gateway-only": "bash -lc 'pnpm --filter dashboard build && pnpm dev:gateway'",
    "start": "bash -lc 'pnpm --filter dashboard build && pnpm start:gateway'",
    "stop": "bash scripts/runtime/stop-all.sh",
    "build": "pnpm -r --if-present run build",
    "lint": "pnpm -r --if-present run lint",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test:unit": "vitest run --config vitest.config.ts $(find packages -path '*/test/unit/*.test.ts' -print)",
    "test:integration": "vitest run --config vitest.config.ts --maxWorkers=4 --testTimeout=30000 --hookTimeout=30000 $(find packages tests -path '*/integration/*.test.ts' -print)",
    "test:integration:queue-watchdog": "vitest run --config vitest.config.ts packages/gateway/test/integration/queue-watchdog.test.ts",
    "test:integration:execution-contract": "vitest run --config vitest.config.ts packages/gateway/test/integration/execution-contract-scope.test.ts",
    "test:integration:backlog-delivery": "vitest run --config vitest.config.ts packages/gateway/test/integration/backlog-delivery-group.test.ts",
    "test:integration:model-routing": "vitest run --config vitest.config.ts packages/gateway/test/integration/model-routing.test.ts",
    "test:integration:gateway-cert": "vitest run --config vitest.config.ts packages/gateway/test/integration/gateway.test.ts",
    "test:ui": "vitest run --config vitest.config.ts $(find tests -path '*/ui/*.test.ts' -print)",
    "test:e2e": "node scripts/testing/run-e2e.mjs",
    "test:browser": "node scripts/testing/run-browser-tests.mjs",
    "test:browser-schedule:cert": "node scripts/testing/run-browser-schedule-certification.mjs",
    "test:interactive-browser:cert": "node scripts/testing/run-interactive-browser-certification.mjs",
    "test:interactive-browser:live": "node scripts/testing/run-live-interactive-browser-certification.mjs",
    "test:fake-provider-e2e:cert": "node scripts/testing/run-fake-provider-e2e-certification.mjs",
    "test:kanban-workboard:cert": "node scripts/testing/run-kanban-workboard-certification.mjs",
    "test:chat-process:cert": "node scripts/testing/run-chat-process-runtime-certification.mjs",
    "test:nightly-cert": "node scripts/testing/run-nightly-certification.mjs",
    "test:live-github-delivery": "node scripts/testing/run-live-github-delivery-certification.mjs",
    "test:live-telegram-process": "node scripts/testing/run-live-telegram-process-certification.mjs",
    "test:live-social-browser": "node scripts/testing/run-live-social-browser-certification.mjs",
    "archive:live-social-browser": "node scripts/testing/archive-live-social-browser-certification.mjs",
    "archive:live-telegram-process": "node scripts/testing/archive-live-telegram-process-certification.mjs",
    "test:roadmap-closure": "tsx scripts/testing/run-roadmap-closure.ts",
    "test:chaos": "node scripts/testing/run-chaos-tests.mjs",
    "test:perf": "node scripts/testing/run-perf-tests.mjs",
    "test": "pnpm test:unit && pnpm test:integration && pnpm test:ui",
    "test:all": "pnpm test && pnpm test:browser && pnpm test:chaos && pnpm test:perf",
    "start:gateway": "tsx --conditions=development packages/gateway/src/index.ts --config config/control-plane.yaml",
    "start:dashboard": "bash -lc 'pnpm --filter dashboard build && pnpm --filter dashboard preview --host 127.0.0.1 --port 4173'",
    "dev:gateway": "tsx watch --conditions=development packages/gateway/src/index.ts --config config/control-plane.yaml",
    "dev:dashboard": "pnpm --filter dashboard dev --host 127.0.0.1 --port 4173",
    "doctor:config": "tsx scripts/runtime/config-doctor.ts",
    "token:generate": "tsx scripts/runtime/generate-token.ts",
    "backup:create": "tsx scripts/runtime/backup.ts",
    "backup:restore": "tsx scripts/runtime/restore.ts",
    "app:reset": "tsx scripts/runtime/reset.ts",
    "monitor:runs": "tsx scripts/runtime/monitor.ts",
    "vault:keygen": "tsx scripts/runtime/vault.ts keygen",
    "vault:bootstrap": "tsx scripts/runtime/vault.ts bootstrap",
    "vault:unlock": "tsx scripts/runtime/vault.ts unlock",
    "vault:rotate-master": "tsx scripts/runtime/vault.ts rotate-master",
    "vault:status": "tsx scripts/runtime/vault.ts status",
    "skills:config": "tsx scripts/runtime/skills.ts",
    "llm:config": "tsx scripts/runtime/llm.ts",
    "ops:housekeeping": "tsx scripts/runtime/housekeeping.ts",
    "agent:config": "tsx scripts/runtime/agents.ts",
    "ops": "tsx scripts/runtime/ops.ts",
    "ops:config:validate": "tsx scripts/runtime/ops.ts config validate",
    "api:inventory": "tsx scripts/runtime/route-inventory.ts --write",
    "api:inventory:check": "tsx scripts/runtime/route-inventory.ts --check",
    "best-in-class:matrix": "node scripts/runtime/best-in-class-audit.mjs --write",
    "best-in-class:matrix:check": "node scripts/runtime/best-in-class-audit.mjs --check",
    "doctor:react": "npx -y react-doctor@latest dashboard --verbose --diff",
    "quality:pipeline": "node scripts/quality/skill-orchestrated-gates.mjs",
    "quality:remediation": "node scripts/quality/remediation-loop.mjs",
    "guardrails:check": "node scripts/quality/lightweight-guardrails.mjs",
    "publish:check": "node scripts/quality/publish-readiness.mjs",
    "obsidian:sync": "node scripts/quality/obsidian-sync.mjs",
    "python:perf": "python3 tools/python_helpers/profile_helper.py",
    "refactor:pass": "node scripts/quality/refactor-pass-checklist.mjs",
    "docker:smoke": "bash scripts/testing/docker-smoke.sh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7",
    "yaml": "^2.9.0"
  }
}
