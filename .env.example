# Minimal ElyzeLabs environment.
# Copy to .env and fill only what you need to start.
# For the full advanced env surface, see env.full.example.
# Then run: make up
# If GHCR images are private, authenticate first with: docker login ghcr.io

# Required for normal API access.
# Recommended: replace this before any public deploy.
# You can also use the onboarding page's Generate Token helper, then paste the
# generated value here as OPS_API_TOKEN and restart ElyzeLabs.
OPS_API_TOKEN=change-me

# Optional GitHub PAT.
# Needed for GitHub-backed delivery flows or cloning private vendor repos such as
# a private Polybot checkout. Public skills and public polyx-cli installs do not require it.
GITHUB_TOKEN=

# Telegram is mandatory for ElyzeLabs. Leave it enabled and store the bot token
# in Vault during onboarding, or provide OPS_TELEGRAM_BOT_TOKEN here directly.
# OPS_TELEGRAM_CHAT_ID is optional and only used as a fixed fallback chat.
OPS_TELEGRAM_ENABLED=true
OPS_TELEGRAM_BOT_TOKEN=
OPS_TELEGRAM_CHAT_ID=

# Required: set one model provider key at minimum.
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# Optional vault auto-unlock after you initialize Vault in the UI.
OPS_VAULT_AUTO_UNLOCK_FROM_ENV=false
OPS_VAULT_ENV_KEY=
