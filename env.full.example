# Ops Control Plane
# Full advanced environment example.
# For the minimal day-one setup, use .env.example instead.
# Copy this file to .env at repository root only if you need the full env surface.
# The gateway autoloads .env on startup.

# Required for authenticated API calls (all non-public /api routes).
# Recommended: generate a fresh value before any public deploy.
# You can also use the onboarding page's Generate Token helper, then paste the
# generated value here as OPS_API_TOKEN and restart ElyzeLabs.
OPS_API_TOKEN=local-dev-token-change-me

# Optional shared GitHub PAT.
# Needed for GitHub-backed delivery flows or cloning private vendor repos such as Polybot.
GITHUB_TOKEN=

# Optional server overrides.
# OPS_SERVER_HOST=0.0.0.0
# OPS_SERVER_PORT=8788
# OPS_COMPANY_NAME=Company

# Optional persistence/runtime overrides.
# OPS_SQLITE_PATH=.ops/state/control-plane.db
# OPS_RUNTIME_DEFAULT=process
# OPS_RUNTIME_WORKSPACE_ROOT=.ops/workspaces
# OPS_RUNTIME_WORKSPACE_STRATEGY=session
# ELYZELABS_GATEWAY_IMAGE=ghcr.io/elyzesolutions/elyzelabs:latest
# OPS_SKILLS_DIRECTORIES=skills,.ops/skills,~/.agents/skills
# OPS_SKILLS_INSTALLER_INSTALL_ROOT=.ops/skills

# Optional prompt context assembly tuning.
# OPS_CONTEXT_ASSEMBLY_ENABLED=true
# OPS_CONTEXT_ASSEMBLY_TOTAL_TOKENS=8192
# OPS_CONTEXT_ASSEMBLY_OVERFLOW_STRATEGY=shrink
# OPS_CONTEXT_ASSEMBLY_TRANSCRIPT_TURNS=12
# OPS_CONTEXT_ASSEMBLY_TRANSCRIPT_MESSAGES=48
# OPS_CONTEXT_ASSEMBLY_MEMORY_TOP_K=6
# OPS_CONTEXT_ASSEMBLY_MEMORY_MIN_SCORE=0.15
# OPS_CONTEXT_ASSEMBLY_RESERVE_INSTRUCTIONS=2200
# OPS_CONTEXT_ASSEMBLY_RESERVE_TASK=2200
# OPS_CONTEXT_ASSEMBLY_RESERVE_TRANSCRIPT=2200
# OPS_CONTEXT_ASSEMBLY_RESERVE_MEMORY=1200
# OPS_CONTEXT_ASSEMBLY_DROP_ORDER=memory_recall,recent_transcript,instructions

# Required Telegram ingress.
OPS_TELEGRAM_ENABLED=true
# OPS_TELEGRAM_BOT_TOKEN=
# OPS_TELEGRAM_BOT_TOKEN=vault://telegram.bot_token
# OPS_TELEGRAM_USE_WEBHOOK=false
# OPS_TELEGRAM_DEBUG_RAW_OUTPUT=false
# OPS_TELEGRAM_DM_SCOPE=peer
# OPS_TELEGRAM_REQUIRE_MENTION=true
# OPS_TELEGRAM_ALLOWLIST=12345,67890
# If vault is enabled and secret name is exactly telegram.bot_token, pointer is optional.

# Optional embedding provider.
# OPS_MEMORY_EMBEDDING_PROVIDER=voyage
# OPS_VOYAGE_API_KEY=
# OPS_VOYAGE_API_KEY=vault://providers.voyage_api_key
# If vault is enabled and secret name is exactly providers.voyage_api_key, pointer is optional.

# Optional OpenRouter runtime credential.
# OPS_OPENROUTER_API_KEY=
# OPS_OPENROUTER_API_KEY=vault://providers.openrouter_api_key
# If vault is enabled and secret name is exactly providers.openrouter_api_key, pointer is optional.

# Optional provider runtime credentials.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# OPS_OPENAI_API_KEY=
# OPS_ANTHROPIC_API_KEY=
# OPS_GOOGLE_API_KEY=
# If matching vault secrets exist (providers.openai_api_key/providers.anthropic_api_key/providers.google_api_key),
# these env vars are auto-wired at runtime.

# Optional built-in vault controls.
# OPS_VAULT_ENABLED=true
# OPS_VAULT_REQUIRE_UNLOCK_ON_STARTUP=false
# OPS_VAULT_AUTO_UNLOCK_FROM_ENV=true
# OPS_VAULT_ENV_KEY=
# Current behavior: this holds the actual vault material used for auto-unlock.
# OPS_VAULT_ALLOW_PASSPHRASE_UNLOCK=true
# OPS_VAULT_PASSPHRASE_SALT=ops-control-plane-vault
# OPS_VAULT_PASSPHRASE_ITERATIONS=120000

# Optional secret-hygiene guard overrides.
# OPS_DISABLE_PLAIN_SECRET_GUARD=true   # disable plaintext-secret startup checks
# OPS_ALLOW_PLAIN_SECRETS=true          # allow plaintext secrets intentionally

# Optional observability and office overrides.
# OPS_OBSERVABILITY_EVENT_BUFFER_SIZE=2000
# OPS_OBSERVABILITY_METRICS_WINDOW_SEC=300
# OPS_OFFICE_ENABLED=true
# OPS_OFFICE_DEFAULT_LAYOUT_NAME=Main Ops Floor

# Optional aggressive housekeeping/pruning controls.
# OPS_HOUSEKEEPING_ENABLED=true
# OPS_HOUSEKEEPING_INTERVAL_SEC=180
# OPS_HOUSEKEEPING_SESSION_DELEGATE_HOURS=1
# OPS_HOUSEKEEPING_SESSION_DASHBOARD_HOURS=6
# OPS_HOUSEKEEPING_SESSION_AGENT_HOURS=6
# OPS_HOUSEKEEPING_SESSION_INTERNAL_HOURS=4
# OPS_HOUSEKEEPING_SESSION_TELEGRAM_HOURS=72
# OPS_HOUSEKEEPING_SESSION_OFFICE_HOURS=168
# OPS_HOUSEKEEPING_SESSION_UNKNOWN_HOURS=4
# OPS_HOUSEKEEPING_RUN_RETENTION_HOURS=24
# OPS_HOUSEKEEPING_MESSAGE_RETENTION_HOURS=24
# OPS_HOUSEKEEPING_REALTIME_RETENTION_HOURS=8
# OPS_HOUSEKEEPING_OFFICE_PRESENCE_RETENTION_HOURS=8
# OPS_HOUSEKEEPING_LLM_USAGE_RETENTION_DAYS=7
# OPS_HOUSEKEEPING_MEMORY_RETENTION_DAYS=14
# OPS_HOUSEKEEPING_AUDIT_RETENTION_DAYS=14
# OPS_HOUSEKEEPING_PROTECTED_SESSION_KEYS=office:ceo-hq
